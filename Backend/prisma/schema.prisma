// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model usuario {
  id String @id @default(uuid())
  nome String
  email String @unique
  senha String 
  cpf String
  cep String


  produto  produto[]
  criando_em DateTime @default(now())
  modificado_em DateTime @default(now())


  @@map ("Usuario")
}

model produto {
  codigo String @id @default(uuid())
  nome String
  validade DateTime
  preco String
  quantidade Int

   
   usuarioId String
   usuario  usuario @relation(fields: [usuarioId], references: [id])

     criando_em DateTime @default(now())
  modificado_em DateTime @updatedAt
  categoria categoria[]
  relatorio relatorio[]

  @@map("Produto")
}


model categoria{
  id String @id @default(uuid())
  nome String
  tipo String @unique

  idproduto String
  Produto produto @relation(fields: [idproduto],references: [codigo])

  @@map("categoria")
 criando_em DateTime? @default(now())
 modificado_em DateTime @updatedAt



}

model relatorio{
  id String @id @default(uuid())
  descricao String
  data DateTime?

  idproduto String
  produto produto @relation(fields: [idproduto],references: [codigo])

  @@map("relatorio")
   criando_em DateTime? @default(now())
 modificado_em DateTime @updatedAt


  
}
 