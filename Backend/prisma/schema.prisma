// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model usuario {
  id String @id @default(uuid())
  nome String
  email String @unique
  senha String 
  cpf String
  cep String


  produto  produto[]
  pedido pedido[]
  criando_em DateTime @default(now())
  modificado_em DateTime @default(now())


  @@map ("Usuario")
}

model produto {
  id String @id @default(uuid())
  nome String
  estoque Int
  preco String
  

   
   usuarioId String
   usuario  usuario @relation(fields: [usuarioId], references: [id])

     criando_em DateTime @default(now())
  modificado_em DateTime @updatedAt
   itens item[]
  
  

  @@map("Produto")
}

model pedido{
  id String @id @default(uuid())
  total String
  data_pedido DateTime

  usuarioId String
  usuario usuario @relation(fields: [usuarioId], references: [id])

  criando_em DateTime @default(now())
  modificado_em DateTime @updatedAt
  itens item[]

  @@map("Pedido")
} 

model item {
  id String @id @default(uuid())
  quantidade Int
  preco String

  produtoId String
  produto produto @relation(fields: [produtoId], references: [id])

  pedidoId String
  pedido pedido @relation(fields: [pedidoId], references: [id])

  criando_em DateTime @default(now())
  modificado_em DateTime @updatedAt

  @@map("Item")

}
